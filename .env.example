# Copy to .env and fill in. Never commit .env.

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Airtable personal access token (needs data.records:read/write on the base)
AIRTABLE_API_KEY=

# The base ID, e.g. appXXXXXXXXXXXXXX (from airtable.com/api)
AIRTABLE_BASE_ID=

# Optional: group chat ID for the weekly schedule post (negative number)
TELEGRAM_GROUP_CHAT_ID=

# Optional: DEBUG / INFO / WARNING (default INFO)
LOG_LEVEL=INFO
